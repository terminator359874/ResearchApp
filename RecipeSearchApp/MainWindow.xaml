<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="RecipeSearchApp.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:RecipeSearchApp.ViewModels"
    Title="Кулинарная База Знаний">

    <Window.SystemBackdrop>
        <MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" Padding="20">
        <Grid.DataContext>
            <vm:MainViewModel />
        </Grid.DataContext>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Меню с доступом к тестам в верхнем правом углу -->
        <CommandBar Grid.Row="0" DefaultLabelPosition="Right" Background="Transparent" HorizontalAlignment="Right">
            <AppBarButton Icon="Repair" Label="Диагностика" Click="OpenDiagnostics_Click" />
            <AppBarButton Icon="View" Label="Монитор кеша" Click="OpenCacheMonitor_Click" />
        </CommandBar>

        <!-- Заголовок -->
        <TextBlock
            Grid.Row="0"
            Text="🍳 Кулинарная База Знаний"
            FontSize="32"
            FontWeight="Bold"
            Margin="0,0,0,20" />

        <!-- Панель поиска -->
        <StackPanel
            Grid.Row="1"
            Spacing="12"
            Margin="0,0,0,20">

            <TextBox
                Text="{Binding SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                PlaceholderText="Введите запрос для полнотекстового поиска (FTS5)..."
                FontSize="16" />

            <!-- Автодополнение -->
            <ItemsControl ItemsSource="{Binding Suggestions}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <TextBlock
                            Text="{Binding}"
                            Foreground="#2E75B6"
                            FontSize="14"
                            Margin="8,2" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Grid ColumnSpacing="12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ComboBox
                    Grid.Column="0"
                    HorizontalAlignment="Stretch"
                    SelectedItem="{Binding SelectedFtsQueryType, Mode=TwoWay}"
                    Header="Тип запроса (FTS5)">
                    <x:String>Простой поиск</x:String>
                    <x:String>Поиск фразы</x:String>
                    <x:String>Логическое И</x:String>
                    <x:String>Логическое ИЛИ</x:String>
                    <x:String>Исключение</x:String>
                    <x:String>Префиксный поиск</x:String>
                    <x:String>Близость слов (NEAR)</x:String>
                </ComboBox>

                <ComboBox
                    Grid.Column="1"
                    SelectedItem="{Binding SelectedAlgorithm, Mode=TwoWay}"
                    Header="Алгоритм подсветки">
                    <x:String>KMP</x:String>
                    <x:String>BM</x:String>
                </ComboBox>

                <Button
                    Grid.Column="2"
                    Content="🔍 Поиск"
                    Command="{Binding SearchCommand}"
                    Style="{StaticResource AccentButtonStyle}"
                    VerticalAlignment="Bottom" />

                <Button
                    Grid.Column="3"
                    Content="📋 Все"
                    Command="{Binding LoadAllCommand}"
                    VerticalAlignment="Bottom" />
            </Grid>
        </StackPanel>

        <!-- Основная область -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <!-- Список рецептов -->
            <ListView
                Grid.Column="0"
                ItemsSource="{Binding Recipes}"
                SelectedItem="{Binding SelectedRecipe, Mode=TwoWay}"
                Margin="0,0,10,0">

                <ListView.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Padding="8">
                            <TextBlock
                                Text="{Binding Title}"
                                FontWeight="SemiBold"
                                FontSize="16" />

                            <TextBlock
                                Text="{Binding Category}"
                                Foreground="Gray"
                                FontSize="13" />

                            <TextBlock
                                FontSize="12"
                                Foreground="#70AD47">
                                <Run Text="⏱" />
                                <Run Text="{Binding PrepTimeMinutes}" />
                                <Run Text="мин • 👁" />
                                <Run Text="{Binding ViewCount}" />
                            </TextBlock>
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Детали рецепта -->
            <ScrollViewer
                Grid.Column="1"
                Padding="10">

                <StackPanel
                    Spacing="16"
                    DataContext="{Binding SelectedRecipe}">

                    <TextBlock
                        Text="{Binding Title}"
                        FontSize="24"
                        FontWeight="Bold" />

                    <StackPanel>
                        <TextBlock
                            Text="Ингредиенты:"
                            FontWeight="SemiBold"
                            FontSize="16"
                            Margin="0,0,0,8" />

                        <TextBlock
                            Text="{Binding Ingredients}"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <StackPanel>
                        <TextBlock
                            Text="Инструкции (с подсветкой):"
                            FontWeight="SemiBold"
                            FontSize="16"
                            Margin="0,0,0,8" />

                        <TextBlock
                            Text="{Binding ElementName=RootGrid, Path=DataContext.HighlightedInstructions}"
                            TextWrapping="Wrap" />
                    </StackPanel>

                    <Border
                        Background="#E2EFD9"
                        Padding="12"
                        CornerRadius="8">

                        <StackPanel Spacing="4">
                            <TextBlock FontSize="13">
                                <Run Text="Категория:" />
                                <Run Text="{Binding Category}" FontWeight="SemiBold" />
                            </TextBlock>

                            <TextBlock FontSize="13">
                                <Run Text="Время приготовления:" />
                                <Run Text="{Binding PrepTimeMinutes}" FontWeight="SemiBold" />
                                <Run Text="мин" />
                            </TextBlock>

                            <TextBlock FontSize="13">
                                <Run Text="Просмотров:" />
                                <Run Text="{Binding ViewCount}" FontWeight="SemiBold" />
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- Статус кеша -->
        <StackPanel
            Grid.Row="3"
            Orientation="Horizontal"
            Spacing="12"
            Margin="0,20,0,0">

            <TextBlock
                Text="{Binding CacheStats}"
                VerticalAlignment="Center"
                Foreground="Gray" />

            <Button
                Content="🔄 Обновить"
                Command="{Binding RefreshCacheStatsCommand}"
                FontSize="12" />
        </StackPanel>
    </Grid>
</Window>
